# ── BFF server environment ────────────────────────────────────────────────
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
# Secret used to sign session tokens. Replace in production.
SESSION_SECRET=change-me-in-production

# ── Kakao Login (real OAuth). Leave blank to use the dev mock. ─────────────
# https://developers.kakao.com → My Application → App Keys (REST API key)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# Must match the Redirect URI registered in the Kakao console:
KAKAO_REDIRECT_URI=http://localhost:8787/api/auth/kakao/callback

# ── PortOne (아임포트) payments (real verify). Leave blank to use the mock. ──
# https://admin.portone.io → 결제연동 → API Keys
PORTONE_API_KEY=
PORTONE_API_SECRET=

# ── eSIM SM-DP+ (placeholder — provider TBD) ──────────────────────────────
SMDP_BASE_URL=
SMDP_API_KEY=
