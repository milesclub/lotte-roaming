# Client (Vite) environment.
# Leave VITE_API_BASE_URL empty to run the standalone demo on local mock adapters.
# Set it to the BFF origin to route auth / payments / eSIM / push through the backend.
VITE_API_BASE_URL=
# Set to "true" in production so social sign-in uses the real provider OAuth redirect.
VITE_USE_OAUTH_REDIRECT=false
